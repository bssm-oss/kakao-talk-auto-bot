<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:fillViewport="true"
    android:fitsSystemWindows="true"
    android:padding="@dimen/space_5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_4"
            app:cardBackgroundColor="@color/colorSurface"
            app:cardCornerRadius="@dimen/radius_md"
            app:cardElevation="0dp"
            app:strokeColor="@color/colorBorder"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/space_5">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <View
                        android:id="@+id/status_indicator"
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/bg_indicator_off"
                        android:backgroundTint="@color/colorDanger" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/space_3"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="상태"
                            android:textColor="@color/colorTextSecondary"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/status_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="알림 접근 필요"
                            android:textColor="@color/colorTextPrimary"
                            android:textSize="20sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:id="@+id/device_name_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_4"
                    android:text="디바이스: 미설정"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="13sp"
                    tools:text="디바이스: Android 테스트폰" />

                <TextView
                    android:id="@+id/text_session_summary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_2"
                    android:text="대상 방 0개 · 최근 감지 방 0개"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="13sp"
                    tools:text="대상 방 3개 · 최근 감지 방 8개" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_4"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/permission_button"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/touch_target"
                        android:layout_marginEnd="@dimen/space_2"
                        android:layout_weight="1"
                        android:text="권한 설정"
                        android:textColor="@color/colorTextPrimary"
                        app:strokeColor="@color/colorBorder" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_manage_rooms"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/touch_target"
                        android:layout_weight="1"
                        android:text="대상 방 관리"
                        android:textColor="@color/colorTextPrimary"
                        app:strokeColor="@color/colorBorder" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_4"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="AI 자동 답장"
                        android:textColor="@color/colorTextPrimary"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_ai_replies"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:showText="false"
                        android:text="" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_2"
                    android:text="OFF여도 메시지는 계속 수집하고 세션을 유지합니다."
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="12sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_5"
                    android:text="화면 모드"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <com.google.android.material.button.MaterialButtonToggleGroup
                    android:id="@+id/theme_toggle_group"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_2"
                    app:checkedButton="@id/theme_button_system"
                    app:selectionRequired="true"
                    app:singleSelection="true">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/theme_button_system"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/touch_target"
                        android:layout_weight="1"
                        android:text="@string/theme_mode_system"
                        android:textColor="@color/colorTextPrimary"
                        app:strokeColor="@color/colorBorder" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/theme_button_light"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/touch_target"
                        android:layout_weight="1"
                        android:text="@string/theme_mode_light"
                        android:textColor="@color/colorTextPrimary"
                        app:strokeColor="@color/colorBorder" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/theme_button_dark"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/touch_target"
                        android:layout_weight="1"
                        android:text="@string/theme_mode_dark"
                        android:textColor="@color/colorTextPrimary"
                        app:strokeColor="@color/colorBorder" />
                </com.google.android.material.button.MaterialButtonToggleGroup>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_profile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_4"
            app:cardBackgroundColor="@color/colorSurface"
            app:cardCornerRadius="@dimen/radius_md"
            app:cardElevation="0dp"
            app:strokeColor="@color/colorBorder"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/space_5">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="응답 설정"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/text_identity_summary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_3"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="14sp"
                    tools:text="이름: 도우미 · 페르소나: 친절하고 짧게 답장" />

                <TextView
                    android:id="@+id/text_provider_summary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_2"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="13sp"
                    tools:text="응답 엔진: 로컬 Kotlin 엔진 · API 키 없음" />

                <TextView
                    android:id="@+id/text_behavior_summary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_2"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="13sp"
                    tools:text="답장 방식: 간결하게 · 트리거: 호출어/멘션만" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_edit_config"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/touch_target"
                    android:layout_marginTop="@dimen/space_4"
                    android:text="응답 설정 편집"
                    android:textColor="@color/colorTextPrimary"
                    app:strokeColor="@color/colorBorder" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_rooms"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_4"
            app:cardBackgroundColor="@color/colorSurface"
            app:cardCornerRadius="@dimen/radius_md"
            app:cardElevation="0dp"
            app:strokeColor="@color/colorBorder"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/space_5">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="대상 방"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/text_room_summary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_3"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="13sp"
                    tools:text="응답 대상 3개 · 전체 저장 4개" />

                <TextView
                    android:id="@+id/text_room_history_summary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_2"
                    android:text="가져온 CSV가 아직 없습니다."
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="13sp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recycler_rooms"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_3"
                    android:clipToPadding="false"
                    android:nestedScrollingEnabled="false"
                    tools:listitem="@layout/bot_item" />

                <TextView
                    android:id="@+id/text_room_empty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_3"
                    android:text="아직 대상 방이 없습니다. 방을 추가한 뒤 메모리와 CSV 기록을 연결하세요."
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="13sp"
                    android:visibility="gone" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_log"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/colorSurface"
            app:cardCornerRadius="@dimen/radius_md"
            app:cardElevation="0dp"
            app:strokeColor="@color/colorBorder"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/space_5">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="최근 로그"
                        android:textColor="@color/colorTextPrimary"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_copy_logs"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/compact_button_height"
                        android:text="복사"
                        android:textColor="@color/colorTextPrimary"
                        app:strokeColor="@color/colorBorder" />
                </LinearLayout>

                <TextView
                    android:id="@+id/log_text"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/log_height"
                    android:layout_marginTop="@dimen/space_3"
                    android:background="@drawable/bg_panel"
                    android:fontFamily="monospace"
                    android:gravity="top|start"
                    android:lineSpacingExtra="@dimen/space_1"
                    android:overScrollMode="always"
                    android:padding="@dimen/space_3"
                    android:scrollbarStyle="insideInset"
                    android:scrollbars="vertical"
                    android:text="아직 수집된 로그가 없습니다."
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="11sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

</androidx.core.widget.NestedScrollView>
